APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true

ASSET_URL=
APP_URL=
VITE_APP_URL=
L5_SWAGGER_CONST_HOST=
L5_SWAGGER_CONST_DESCRIPTION="Local Server"

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
FILESYSTEM_DISK=local

MEMCACHED_HOST=127.0.0.1

# Redis Configuration
# Uses predis (pure PHP) - no extension required
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2
REDIS_SESSION_DB=3

# Cache, Queue, Session Drivers
# Set to 'redis' to use Redis for caching, queues, and sessions
# Database isolation: cache=DB1, queue=DB2, session=DB3
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_CONNECTION=session
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

JWT_SECRET=

CREDENTIALS_SEEDER_ADMIN_EMAIL=
CREDENTIALS_SEEDER_ADMIN_NAME=
CREDENTIALS_SEEDER_ADMIN_PASSWORD=

CREDENTIALS_LAB_1_USERNAME=
CREDENTIALS_LAB_1_PASSWORD=
CREDENTIALS_LAB_2_USERNAME=
CREDENTIALS_LAB_2_PASSWORD=
CREDENTIALS_LAB_3_USERNAME=
CREDENTIALS_LAB_3_PASSWORD=

SFTP_HOST= # Replace with the host of your SFTP server
SFTP_USERNAME="" # The name of your SFTP user
SFTP_PASSWORD="" # The password of your SFTP user
SFTP_PORT=22 # If your server is not using the default port, replace it
SFTP_ROOT="/"

ODB_USERNAME=
ODB_PASSWORD=

AI_REVIEW_LOGIN=
AI_REVIEW_ANALYSIS=
AI_REVIEW_TESTING=

ODB_API_USERNAME=
ODB_API_PASSWORD=

WEBHOOK_AI_RESULT_TOKEN=